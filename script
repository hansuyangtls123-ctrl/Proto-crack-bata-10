-- ==================== 타겟 관련 ====================
local function getRandomTarget()
    local candidates = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            table.insert(candidates, p)
        end
    end
    if #candidates > 0 then
        return candidates[math.random(1, #candidates)]
    end
    return nil
end

local function isTargetValid(target)
    if not target then return false end
    local char = target.Character
    if not char then return false end
    local humanoid = char:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

-- ==================== UI 업데이트 ====================
local function updateToggleUI()
    if isLocked then
        toggleButton.Text = "ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
    else
        toggleButton.Text = "OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    end
end

-- ==================== 버튼 연결 ====================
toggleButton.MouseButton1Click:Connect(function()
    isLocked = not isLocked
    if isLocked then
        lockedTarget = getRandomTarget()
    else
        lockedTarget = nil
    end
    updateToggleUI()
end)

minimizeBtn.MouseButton1Click:Connect(function()
    minimized = true
    mainFrame.Visible = false
    miniFrame.Visible = true
end)

miniFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        minimized = false
        mainFrame.Visible = true
        miniFrame.Visible = false
    end
end)

-- ==================== 메인 루프 ====================
RunService.RenderStepped:Connect(function()
    if not isLocked or not lockedTarget then return end

    if not isTargetValid(lockedTarget) then
        lockedTarget = getRandomTarget()
        if not lockedTarget then
            isLocked = false
            updateToggleUI()
            return
        end
    end

    local targetChar = lockedTarget.Character
    local myChar = player.Character
    
    if targetChar and myChar then
        local hrp = targetChar:FindFirstChild("HumanoidRootPart")
        local head = targetChar:FindFirstChild("Head")
        local myHrp = myChar:FindFirstChild("HumanoidRootPart")

        if hrp and head and myHrp then
            -- 에임락
            camera.CFrame = CFrame.new(camera.CFrame.Position, head.Position)
            
            -- 뒤로 TP
            local backPos = hrp.Position - (hrp.CFrame.LookVector * tpDistance)
            myHrp.CFrame = CFrame.new(backPos, hrp.Position)
        end
    end
end)

updateToggleUI()
print("✅ Proto-crack-arcode Random Tracker 로드됨")
